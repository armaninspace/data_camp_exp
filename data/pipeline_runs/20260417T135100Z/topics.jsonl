{"topic_id": "24593_topic_case-study-visually-selecting-a-stock-that-improves-your-existing-portfolio", "course_id": "24593", "chapter_id": "24593_ch4", "chapter_title": "Case study: Visually Selecting a Stock That Improves Your Existing\nPortfolio", "label": "Case study: Visually Selecting a Stock That Improves Your Existing\nPortfolio", "aliases": [], "topic_type": "concept", "prerequisites": [], "contrasts": [], "confusions": [], "evidence": [{"field": "syllabus[3].title", "excerpt": "Case study: Visually Selecting a Stock That Improves Your Existing\nPortfolio"}], "importance": 0.5}
{"topic_id": "24594_topic_flight-data", "course_id": "24594", "chapter_id": "24594_ch1", "chapter_title": "Flight Data", "label": "Flight Data", "aliases": [], "topic_type": "concept", "prerequisites": [], "contrasts": [], "confusions": [], "evidence": [{"field": "syllabus[0].title", "excerpt": "Flight Data"}, {"field": "syllabus[0].summary", "excerpt": "You've been hired to understand the travel needs of tourists\nvisiting the Boston area. As your first assignment on the job,\nyou'll practice the skills you've learned for time series data\nmanipulation in R by exploring data on flights arriving at Boston's\nLogan International Airport (BOS) using xts & zoo."}], "importance": 0.6}
{"topic_id": "24594_topic_weather-data", "course_id": "24594", "chapter_id": "24594_ch2", "chapter_title": "Weather Data", "label": "Weather Data", "aliases": [], "topic_type": "concept", "prerequisites": [], "contrasts": [], "confusions": [], "evidence": [{"field": "syllabus[1].title", "excerpt": "Weather Data"}, {"field": "syllabus[1].summary", "excerpt": "In this chapter, you'll expand your time series data library to\ninclude weather data in the Boston area. Before you can conduct any\nanalysis, you'll need to do some data manipulation, including\nmerging multiple xts objects and isolating certain periods of the\ndata. It's a great opportunity for more practice!"}], "importance": 0.6}
{"topic_id": "24594_topic_economic-data", "course_id": "24594", "chapter_id": "24594_ch3", "chapter_title": "Economic Data", "label": "Economic Data", "aliases": [], "topic_type": "concept", "prerequisites": [], "contrasts": [], "confusions": [], "evidence": [{"field": "syllabus[2].title", "excerpt": "Economic Data"}, {"field": "syllabus[2].summary", "excerpt": "Now it's time to go further afield. In addition to flight delays,\nyour client is interested in how Boston's tourism industry is\naffected by economic trends. You'll need to manipulate some time\nseries data on economic indicators, including GDP per capita and\nunemployment in the United States in general and Massachusetts (MA)\nin particular."}], "importance": 0.6}
{"topic_id": "24594_topic_sports-data", "course_id": "24594", "chapter_id": "24594_ch4", "chapter_title": "Sports Data", "label": "Sports Data", "aliases": [], "topic_type": "concept", "prerequisites": [], "contrasts": [], "confusions": [], "evidence": [{"field": "syllabus[3].title", "excerpt": "Sports Data"}, {"field": "syllabus[3].summary", "excerpt": "Having exhausted other options, your client now believes Boston's\ntourism industry must be related to the success of local sports\nteams. In your final task on this project, your supervisor has asked\nyou to assemble some time series data on Boston's sports teams over\nthe past few years."}], "importance": 0.6}
